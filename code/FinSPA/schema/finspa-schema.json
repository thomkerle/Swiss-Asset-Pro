{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FinSPA Projekt Schema",
  "type": "object",
  "required": ["version", "lastModified", "banks", "budget"],
  "properties": {
    "version": { "type": "string" },
    "banks": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "budget": {
      "type": "object",
      "properties": {
        "incomeSources": { "type": "array", "items": { "$ref": "#/$defs/budgetEntry" } },
        "expenses": { "type": "array", "items": { "$ref": "#/$defs/budgetEntry" } }
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "name", "type"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "enum": ["bank", "category", "asset"] },
        "assetClass": { "type": "string" },
        "currency": { "type": "string" },
        "children": { "type": "array", "items": { "$ref": "#/$defs/node" } },
        "balances": { "type": "array" }
      }
    },
    "budgetEntry": {
      "type": "object",
      "required": ["id", "name", "amount", "frequency"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "frequency": { "enum": ["monthly", "yearly"] }
      }
    }
  }
}