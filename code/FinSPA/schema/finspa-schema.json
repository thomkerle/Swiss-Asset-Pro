{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FinSPA Projekt Schema",
  "type": "object",
  "required": ["version", "settings", "banks", "budget"],
  "properties": {
    "version": { "type": "string" },
    "settings": {
      "type": "object",
      "required": ["bookingCategories"],
      "properties": {
        "baseCurrency": { "type": "string" },
        "aiEnabled": { "type": "boolean" },
        "aiModels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "icon": { "type": "string" }
            }
          }
        },
        "assetClasses": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "bookingCategories": { "type": "object" }
      }
    },
    "banks": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "budget": { "type": "object" }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "name", "type"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "enum": ["bank", "category", "asset"] },
        "assetClass": { "type": "string" },
        "isLiquid": { "type": "boolean" },
        "currency": { "type": "string" },
        "exchangeRate": { "type": ["string", "number"] },
        "children": { "type": "array", "items": { "$ref": "#/$defs/node" } },
        "balances": { "type": "array" },
        "bookings": { "type": "array" }
      }
    }
  }
}