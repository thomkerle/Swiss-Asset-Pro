{
  "name": "finspa-desktop",
  "version": "0.9.2-Beta",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.finspa.app",
    "productName": "FinSPA Pro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.js",
      "app.zip",
      "build/FinSPA_Logo_Modern.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/FinSPA_Logo_Modern.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/FinSPA_Logo_Modern.icns"
    }
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "overrides": {
    "@noble/hashes": "1.3.2"
  },
  "description": "",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
